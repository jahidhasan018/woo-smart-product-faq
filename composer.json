{
    "name": "woo-smart-product-faq",
    "description": "WooCommerce Smart FAQ plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpstan/phpstan": "^1.11",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "php-stubs/wordpress-stubs": "^6.4",
        "php-stubs/woocommerce-stubs": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "WooSmartFaq\\": "src/php/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WooSmartFaq\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist",
        "phpcs": "phpcs --standard=phpcs.xml",
        "phpcbf": "phpcbf --standard=phpcs.xml",
        "phpstan": "phpstan analyse --level=5 src/php/"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
