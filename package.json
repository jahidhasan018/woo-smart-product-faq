{
    "name": "woo-smart-product-faq",
    "version": "1.0.0",
    "description": "WooCommerce Smart FAQ plugin",
    "private": true,
    "license": "GPL-2.0-or-later",
    "scripts": {
        "build": "wp-scripts build",
        "start": "wp-scripts start",
        "lint:js": "wp-scripts lint-js src/js/",
        "lint:style": "wp-scripts lint-style src/scss/",
        "test:unit": "wp-scripts test-unit-js",
        "test:e2e": "playwright test",
        "packages-update": "wp-scripts packages-update"
    },
    "devDependencies": {
        "@wordpress/scripts": "^30.0.0",
        "@wordpress/e2e-test-utils-playwright": "^0.22.0",
        "@playwright/test": "^1.44.0",
        "@testing-library/react": "^16.0.0",
        "@testing-library/user-event": "^14.5.0",
        "@testing-library/jest-dom": "^6.4.0"
    },
    "dependencies": {
        "@wordpress/api-fetch": "^6.44.0",
        "@wordpress/block-editor": "^13.0.0",
        "@wordpress/blocks": "^13.0.0",
        "@wordpress/components": "^28.0.0",
        "@wordpress/compose": "^7.0.0",
        "@wordpress/data": "^10.0.0",
        "@wordpress/element": "^6.0.0",
        "@wordpress/hooks": "^4.0.0",
        "@wordpress/i18n": "^5.0.0",
        "@wordpress/server-side-render": "^5.0.0"
    },
    "jest": {
        "preset": "@wordpress/jest-preset-default",
        "setupFilesAfterFramework": [
            "@testing-library/jest-dom"
        ],
        "testMatch": [
            "**/tests/js/**/*.test.{js,jsx}"
        ],
        "collectCoverageFrom": [
            "src/js/**/*.{js,jsx}",
            "!src/js/blocks/faq-block/block.json"
        ]
    }
}
